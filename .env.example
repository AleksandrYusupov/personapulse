NODE_ENV="development"
PROCESS_ROLE="all"
PORT="3001"
FRONTEND_ORIGIN="http://localhost:3000"

# Required for runtime Supabase API/Storage access.
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="SERVICE_ROLE_KEY"
SUPABASE_SCHEMA="inception-1-test"
MEDIA_BUCKET="personapulse-media"

# Required for live migrations. Supabase URL + service role cannot execute SQL migrations.
SUPABASE_DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres"

# Required for Gemini agent calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Required to let character agents call the private image MCP service.
IMAGE_MCP_URL="http://localhost:3002/mcp"
IMAGE_MCP_AUDIENCE=""
IMAGE_MCP_CONTEXT_SIGNING_SECRET="CHANGE_ME_TO_RANDOM_32_BYTES"
IMAGE_MCP_LOCAL_BEARER_TOKEN=""
AGENT_MULTIMODAL_IMAGE_LIMIT="6"
AGENT_MULTIMODAL_IMAGE_BYTE_BUDGET="12582912"
SILENCE_NORMAL_MIN_SECONDS="5"
SILENCE_NORMAL_MAX_SECONDS="10"
SILENCE_DEFAULT_SECONDS="7"
SILENCE_IGNORED_PAUSE_SECONDS="180"
SILENCE_ABSOLUTE_MAX_SECONDS="300"

# Required server secrets.
ADMIN_API_TOKEN="CHANGE_ME"
SESSION_SECRET_PEPPER="CHANGE_ME_TO_RANDOM_32_BYTES"
PROMPT_CACHE_MAX_AGE_MS="300000"
AGENT_ANALYSIS_CONCURRENCY="4"
AGENT_RESPONSE_CONCURRENCY="2"
AGENT_IDLE_POLL_MS="250"
